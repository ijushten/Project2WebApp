<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="nav">
    <a class="logo" href="/">LessonAI</a>
    <div class="nav-links">
      <a href="/signin">Sign In</a>
    </div>
  </nav>

  <main class="auth-page">
    <section class="auth-card">
      <h1>Create your account</h1>
      <p>Sign up to start saving AI-generated lesson plans.</p>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/signup" method="POST" class="form">
        <label for="username">Username</label>
        <input id="username" name="username" type="text" value="<%= values.username || '' %>" placeholder="justin" required>

        <label for="email">Email</label>
        <input id="email" name="email" type="email" value="<%= values.email || '' %>" placeholder="test@example.com" required>

        <label for="password">Password</label>
        <input id="password" name="password" type="password" placeholder="At least 6 characters" required>

        <button class="button full" type="submit">Sign Up</button>
      </form>

      <p class="switch-link">Already have an account? <a href="/signin">Sign in</a></p>
    </section>
  </main>
</body>
</html>
