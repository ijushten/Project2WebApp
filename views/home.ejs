<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <nav class="nav">
    <a class="logo" href="/">LessonAI</a>
    <div class="nav-links">
      <a href="/signup">Sign Up</a>
      <a href="/signin">Sign In</a>
    </div>
  </nav>

  <main class="hero">
    <section class="hero-text">
      <h1>Create classroom lesson plans.</h1>
      <p>LessonAI is a full stack app for generating and saving AI lesson plans.</p>
      <a class="button" href="/signup">Get Started</a>
    </section>

    <section class="preview-card">
      <h2>Lesson preview</h2>
      <p>Subject, topic, grade level, learning goal, and lesson activities will appear here.</p>
    </section>
  </main>
</body>
</html>
